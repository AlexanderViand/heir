diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1234567..abcdefg 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -18,13 +18,20 @@ find_package(CUDAToolkit 11.8 REQUIRED)

 include(FetchContent)
 option(BUILD_TESTS OFF)
+
+# When building inside bazel (rules_foreign_cc), we need EXCLUDE_FROM_ALL
+# to prevent FetchContent subdeps from being included in cmake install.
 FetchContent_Declare(
   rmm
   GIT_REPOSITORY https://github.com/rapidsai/rmm
   GIT_TAG        branch-22.12
   GIT_SHALLOW
+  EXCLUDE_FROM_ALL
 )
 FetchContent_MakeAvailable(rmm)
 message(STATUS "RMM source dir: ${rmm_SOURCE_DIR}")

 # options
 option(ENABLE_EXTENSION "Enable extension sources" ON)
+
+# Install the cheddar library and headers
+install(TARGETS cheddar LIBRARY DESTINATION lib)
+install(DIRECTORY include/ DESTINATION include)
