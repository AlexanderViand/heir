diff --git a/CMakeLists.txt b/CMakeLists.txt
index 323e218..9015d4f 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -24,8 +24,11 @@ FetchContent_Declare(
   GIT_REPOSITORY https://github.com/rapidsai/rmm
   GIT_TAG        branch-22.12
   GIT_SHALLOW
+  EXCLUDE_FROM_ALL
 )
 FetchContent_MakeAvailable(rmm)
+# spdlog is fetched transitively by RMM
+FetchContent_GetProperties(spdlog)
 message(STATUS "RMM source dir: ${rmm_SOURCE_DIR}")
 
 # options
@@ -93,7 +96,7 @@ target_link_libraries(cheddar
 )
 
 target_include_directories(cheddar
-  PUBLIC include
+  PUBLIC include ${CUDAToolkit_INCLUDE_DIRS} ${rmm_SOURCE_DIR}/include
 )
 
 target_compile_options(cheddar PRIVATE
@@ -112,3 +115,12 @@ if (BUILD_UNITTEST)
   message(STATUS "Building unit tests")
   add_subdirectory(unittest)
 endif()
+
+# Install targets for bazel compatibility
+install(TARGETS cheddar LIBRARY DESTINATION lib)
+install(DIRECTORY include/ DESTINATION include)
+# Install transitive dep headers leaked by CHEDDAR's public API
+install(DIRECTORY ${rmm_SOURCE_DIR}/include/ DESTINATION include)
+if(spdlog_SOURCE_DIR)
+  install(DIRECTORY ${spdlog_SOURCE_DIR}/include/ DESTINATION include)
+endif()
